{
  "commands": {
    "capabilities": {
      "id": "capabilities",
      "name": "Get Capabilities",
      "description": "获取客户端支持的所有命令列表",
      "category": "system",
      "parameters": [],
      "returns": {
        "type": "object",
        "properties": {
          "capabilities": {
            "type": "array",
            "description": "命令列表"
          }
        }
      }
    },
    "system.info": {
      "id": "system.info",
      "name": "Get System Info",
      "description": "获取系统信息，包括主机名、操作系统版本、架构、用户名、运行时间、内存和CPU信息",
      "category": "system",
      "parameters": [],
      "returns": {
        "type": "object",
        "properties": {
          "hostname": { "type": "string", "description": "主机名" },
          "os_type": { "type": "string", "description": "操作系统类型" },
          "os_version": { "type": "string", "description": "操作系统版本" },
          "arch": { "type": "string", "description": "系统架构" },
          "username": { "type": "string", "description": "当前用户名" },
          "uptime_secs": { "type": "number", "description": "系统运行时间（秒）" },
          "total_memory_gb": { "type": "number", "description": "总内存（GB）" },
          "available_memory_gb": { "type": "number", "description": "可用内存（GB）" },
          "cpu_count": { "type": "number", "description": "CPU核心数" },
          "cpu_usage_percent": { "type": "number", "description": "CPU使用率（%）" }
        }
      }
    },
    "system.reboot": {
      "id": "system.reboot",
      "name": "Reboot System",
      "description": "重启系统",
      "category": "system",
      "parameters": [],
      "returns": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "description": "是否成功" },
          "message": { "type": "string", "description": "消息" }
        }
      }
    },
    "system.shutdown": {
      "id": "system.shutdown",
      "name": "Shutdown System",
      "description": "关闭系统",
      "category": "system",
      "parameters": [],
      "returns": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "description": "是否成功" },
          "message": { "type": "string", "description": "消息" }
        }
      }
    },
    "process.list": {
      "id": "process.list",
      "name": "List Processes",
      "description": "获取当前运行的进程列表",
      "category": "process",
      "parameters": [],
      "returns": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "pid": { "type": "number", "description": "进程ID" },
            "name": { "type": "string", "description": "进程名称" },
            "cmd": { "type": "string", "description": "命令行" },
            "cpu_percent": { "type": "number", "description": "CPU使用率" },
            "memory_mb": { "type": "number", "description": "内存使用（MB）" },
            "status": { "type": "string", "description": "进程状态" }
          }
        }
      }
    },
    "process.stop": {
      "id": "process.stop",
      "name": "Stop Process",
      "description": "停止指定PID的进程",
      "category": "process",
      "parameters": [
        { "name": "pid", "type": "number", "required": true, "description": "进程ID" },
        { "name": "force", "type": "boolean", "required": false, "description": "是否强制终止" }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "description": "是否成功" },
          "message": { "type": "string", "description": "消息" }
        }
      }
    },
    "software.list": {
      "id": "software.list",
      "name": "List Software",
      "description": "获取已安装的软件列表",
      "category": "software",
      "parameters": [],
      "returns": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string", "description": "软件名称" },
            "version": { "type": "string", "description": "版本号" },
            "publisher": { "type": "string", "description": "发布者" },
            "install_path": { "type": "string", "description": "安装路径" }
          }
        }
      }
    },
    "software.search": {
      "id": "software.search",
      "name": "Search Software",
      "description": "搜索可安装的软件包",
      "category": "software",
      "parameters": [
        { "name": "query", "type": "string", "required": true, "description": "搜索关键词" }
      ],
      "returns": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string", "description": "软件名称" },
            "version": { "type": "string", "description": "版本号" },
            "publisher": { "type": "string", "description": "发布者" },
            "install_path": { "type": "string", "description": "安装路径" }
          }
        }
      }
    },
    "software.install": {
      "id": "software.install",
      "name": "Install Software",
      "description": "安装指定的软件包",
      "category": "software",
      "parameters": [
        { "name": "package", "type": "string", "required": true, "description": "软件包名称或ID" },
        { "name": "silent", "type": "boolean", "required": false, "description": "是否静默安装" }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "description": "是否成功" },
          "message": { "type": "string", "description": "消息" }
        }
      }
    },
    "software.uninstall": {
      "id": "software.uninstall",
      "name": "Uninstall Software",
      "description": "卸载指定的软件包",
      "category": "software",
      "parameters": [
        { "name": "package", "type": "string", "required": true, "description": "软件包名称或ID" }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "description": "是否成功" },
          "message": { "type": "string", "description": "消息" }
        }
      }
    },
    "env.list": {
      "id": "env.list",
      "name": "List Environment Variables",
      "description": "获取环境变量列表",
      "category": "environment",
      "parameters": [
        { "name": "scope", "type": "string", "required": false, "description": "作用域: user, system, session" }
      ],
      "returns": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string", "description": "变量名" },
            "value": { "type": "string", "description": "变量值" }
          }
        }
      }
    },
    "env.get": {
      "id": "env.get",
      "name": "Get Environment Variable",
      "description": "获取指定环境变量的值",
      "category": "environment",
      "parameters": [
        { "name": "name", "type": "string", "required": true, "description": "变量名" },
        { "name": "scope", "type": "string", "required": false, "description": "作用域: user, system, session" }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "变量名" },
          "value": { "type": "string", "description": "变量值" }
        }
      }
    },
    "env.set": {
      "id": "env.set",
      "name": "Set Environment Variable",
      "description": "设置环境变量",
      "category": "environment",
      "parameters": [
        { "name": "name", "type": "string", "required": true, "description": "变量名" },
        { "name": "value", "type": "string", "required": true, "description": "变量值" },
        { "name": "scope", "type": "string", "required": false, "description": "作用域: user, system, session" }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "description": "是否成功" },
          "message": { "type": "string", "description": "消息" }
        }
      }
    },
    "env.delete": {
      "id": "env.delete",
      "name": "Delete Environment Variable",
      "description": "删除指定的环境变量",
      "category": "environment",
      "parameters": [
        { "name": "name", "type": "string", "required": true, "description": "变量名" },
        { "name": "scope", "type": "string", "required": false, "description": "作用域: user, system, session" }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "description": "是否成功" },
          "message": { "type": "string", "description": "消息" }
        }
      }
    },
    "file.list": {
      "id": "file.list",
      "name": "List Directory",
      "description": "列出指定目录的内容",
      "category": "file",
      "parameters": [
        { "name": "path", "type": "string", "required": false, "description": "目录路径" }
      ],
      "returns": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string", "description": "文件名" },
            "path": { "type": "string", "description": "完整路径" },
            "is_dir": { "type": "boolean", "description": "是否目录" },
            "size_bytes": { "type": "number", "description": "文件大小（字节）" },
            "modified": { "type": "number", "description": "修改时间戳" }
          }
        }
      }
    },
    "file.read": {
      "id": "file.read",
      "name": "Read File",
      "description": "读取文件内容",
      "category": "file",
      "parameters": [
        { "name": "path", "type": "string", "required": true, "description": "文件路径" }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "文件路径" },
          "content": { "type": "string", "description": "文件内容" }
        }
      }
    },
    "file.write": {
      "id": "file.write",
      "name": "Write File",
      "description": "写入内容到文件",
      "category": "file",
      "parameters": [
        { "name": "path", "type": "string", "required": true, "description": "文件路径" },
        { "name": "content", "type": "string", "required": true, "description": "文件内容" }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "description": "是否成功" },
          "message": { "type": "string", "description": "消息" }
        }
      }
    },
    "file.delete": {
      "id": "file.delete",
      "name": "Delete File",
      "description": "删除指定的文件或目录",
      "category": "file",
      "parameters": [
        { "name": "path", "type": "string", "required": true, "description": "文件或目录路径" }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "description": "是否成功" },
          "message": { "type": "string", "description": "消息" }
        }
      }
    },
    "file.create_dir": {
      "id": "file.create_dir",
      "name": "Create Directory",
      "description": "创建目录",
      "category": "file",
      "parameters": [
        { "name": "path", "type": "string", "required": true, "description": "目录路径" },
        { "name": "recursive", "type": "boolean", "required": false, "description": "是否递归创建" }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "description": "是否成功" },
          "message": { "type": "string", "description": "消息" }
        }
      }
    },
    "file.copy": {
      "id": "file.copy",
      "name": "Copy File",
      "description": "复制文件或目录",
      "category": "file",
      "parameters": [
        { "name": "src", "type": "string", "required": true, "description": "源路径" },
        { "name": "dst", "type": "string", "required": true, "description": "目标路径" }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "description": "是否成功" },
          "message": { "type": "string", "description": "消息" }
        }
      }
    },
    "file.move": {
      "id": "file.move",
      "name": "Move File",
      "description": "移动文件或目录",
      "category": "file",
      "parameters": [
        { "name": "src", "type": "string", "required": true, "description": "源路径" },
        { "name": "dst", "type": "string", "required": true, "description": "目标路径" }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "description": "是否成功" },
          "message": { "type": "string", "description": "消息" }
        }
      }
    },
    "file.download": {
      "id": "file.download",
      "name": "Download File",
      "description": "从URL下载文件",
      "category": "file",
      "parameters": [
        { "name": "url", "type": "string", "required": true, "description": "下载链接" },
        { "name": "dest", "type": "string", "required": true, "description": "目标保存路径" }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "description": "是否成功" },
          "path": { "type": "string", "description": "保存路径" }
        }
      }
    },
    "config.get": {
      "id": "config.get",
      "name": "Get Config",
      "description": "获取配置值",
      "category": "config",
      "parameters": [
        { "name": "path", "type": "string", "required": true, "description": "配置路径" }
      ],
      "returns": {
        "type": "any",
        "description": "配置值"
      }
    },
    "config.set": {
      "id": "config.set",
      "name": "Set Config",
      "description": "设置配置值",
      "category": "config",
      "parameters": [
        { "name": "path", "type": "string", "required": true, "description": "配置路径" },
        { "name": "value", "type": "any", "required": true, "description": "配置值" }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "description": "是否成功" },
          "message": { "type": "string", "description": "消息" }
        }
      }
    },
    "shell.execute": {
      "id": "shell.execute",
      "name": "Execute Shell Command",
      "description": "执行Shell命令并返回输出",
      "category": "shell",
      "parameters": [
        { "name": "command", "type": "string", "required": true, "description": "要执行的命令" },
        { "name": "timeout", "type": "number", "required": false, "description": "超时时间（秒）" }
      ],
      "returns": {
        "type": "object",
        "properties": {
          "stdout": { "type": "string", "description": "标准输出" },
          "stderr": { "type": "string", "description": "标准错误" },
          "exit_code": { "type": "number", "description": "退出码" },
          "platform": { "type": "string", "description": "平台" }
        }
      }
    }
  }
}
